graph TB
    subgraph SOURCES["LOG SOURCES"]
        direction TB
        FG["🔥 FortiGate<br/>UDP/TCP Syslog :514"]
        WIN["🪟 Windows Events<br/>WEF / Agent Push"]
        M365["☁️ M365 / Entra ID<br/>Management Activity API"]
        AZ["⚡ Azure Activity<br/>Monitor REST API"]
        SYS["📡 Generic Syslog<br/>Meraki · Nutanix · Linux"]
    end

    subgraph INGESTION["INGESTION LAYER"]
        direction TB
        SYSLOG["SyslogListener<br/><i>syslog_listener.h/cpp</i><br/>UDP + TCP + TLS<br/>poll()-based I/O"]
        POLLER["HttpPoller<br/><i>http_poller.h/cpp</i><br/>OAuth2 Client Credentials<br/>Periodic REST Polling"]
        RING["RingBuffer&lt;65536&gt;<br/><i>ring_buffer.h</i><br/>Lock-free MPSC<br/>Heap-allocated slots"]
    end

    subgraph PARSERS["PARSER PIPELINE"]
        direction TB
        P_INT["Parser Interface<br/><i>parser.h</i><br/>parse(RawMessage) → Event"]
        P_FG["FortiGateParser<br/><i>fortigate_parser.h/cpp</i><br/>Key=Value extraction<br/>198 lines"]
        P_WIN["WindowsParser<br/><i>windows_parser.h/cpp</i><br/>XML + JSON formats<br/>25+ EventID mappings<br/>364 lines"]
        P_M365["M365Parser<br/><i>m365_parser.h/cpp</i><br/>Office 365 audit JSON<br/>30+ operation mappings<br/>247 lines"]
        P_AZ["AzureParser<br/><i>azure_parser.h/cpp</i><br/>Activity log JSON<br/>Resource categorization<br/>200 lines"]
        P_SYS["SyslogParser<br/><i>syslog_parser.h/cpp</i><br/>RFC 3164 + 5424<br/>Catch-all fallback<br/>180 lines"]
    end

    subgraph SCHEMA["COMMON EVENT SCHEMA"]
        EVT["Event struct<br/><i>common/event.h</i><br/>event_id · timestamp · source_type<br/>severity · category · action · outcome<br/>src_ip · dst_ip · user · raw<br/>metadata JSON"]
    end

    subgraph RULES["DETECTION ENGINE"]
        direction TB
        RLOAD["Rule Loader<br/><i>rules/rule.h/cpp</i><br/>YAML parsing<br/>Filter · Threshold · Sequence · ValueList"]
        RENG["RuleEngine<br/><i>rules/rule_engine.h/cpp</i><br/>Sliding windows · Sequence state<br/>Cooldown · Alert callbacks<br/>388 lines"]
        RYAML["YAML Rule Files<br/><i>config/rules/*.yaml</i><br/>19 rules across 4 files<br/>FortiGate · Windows · M365 · Azure"]
    end

    subgraph STORAGE["STORAGE LAYER"]
        direction TB
        SENG["StorageEngine<br/><i>storage/storage_engine.h/cpp</i><br/>Batched inserts · WAL mode<br/>Daily DB rotation<br/>615 lines"]
        SQLITE[("SQLite + FTS5<br/><i>outpost-YYYY-MM-DD.db</i><br/>events table + FTS index<br/>alerts table<br/>Daily partitioning")]
        RET["Retention Manager<br/><i>storage/retention.cpp</i><br/>Auto-delete DBs > N days"]
    end

    subgraph API["REST API"]
        direction TB
        SRV["ApiServer<br/><i>api/server.h/cpp</i><br/>cpp-httplib<br/>CORS enabled"]
        EP_H["/api/health"]
        EP_E["/api/events?q=&start=&end="]
        EP_S["/api/stats/*<br/>sources · severity · categories<br/>top-ips · top-users · timeline"]
    end

    subgraph FRONTEND["REACT FRONTEND"]
        DASH["Dashboard<br/><i>outpost-dashboard.jsx</i><br/>Stat cards · Timeline chart<br/>Breakdown panels · Event explorer<br/>Auto-refresh · FTS search"]
    end

    subgraph INFRA["INFRASTRUCTURE"]
        direction LR
        MAIN["main.cpp<br/>Thread orchestration<br/>Signal handling<br/>194 lines"]
        LOG["Logger<br/><i>common/logger.h/cpp</i><br/>spdlog wrapper<br/>Console + rotating file"]
        UTIL["Utils<br/><i>common/utils.h</i><br/>UUID v4 · now_ms()<br/>Date strings · ISO 8601"]
    end

    %% Data flow
    FG -->|syslog| SYSLOG
    WIN -->|HTTP POST| SYSLOG
    SYS -->|syslog| SYSLOG
    M365 -->|REST| POLLER
    AZ -->|REST| POLLER

    SYSLOG -->|RawMessage| RING
    POLLER -->|RawMessage| RING

    RING -->|try_pop| P_INT
    P_INT --> P_FG
    P_INT --> P_WIN
    P_INT --> P_M365
    P_INT --> P_AZ
    P_INT --> P_SYS

    P_FG --> EVT
    P_WIN --> EVT
    P_M365 --> EVT
    P_AZ --> EVT
    P_SYS --> EVT

    EVT -->|insert| SENG
    EVT -->|evaluate| RENG

    RYAML --> RLOAD
    RLOAD --> RENG
    RENG -->|insert_alert| SENG
    SENG --> SQLITE
    RET --> SQLITE

    SQLITE --> SRV
    SRV --> EP_H
    SRV --> EP_E
    SRV --> EP_S

    EP_H --> DASH
    EP_E --> DASH
    EP_S --> DASH

    MAIN --> SYSLOG
    MAIN --> POLLER
    MAIN --> RENG
    MAIN --> SRV

    %% Styling
    classDef source fill:#1e3a5f,stroke:#3b82f6,color:#e2e8f0
    classDef ingest fill:#1a2e1a,stroke:#22c55e,color:#e2e8f0
    classDef parse fill:#2d1f3d,stroke:#a855f7,color:#e2e8f0
    classDef schema fill:#3d2e1a,stroke:#f97316,color:#e2e8f0
    classDef rule fill:#3d1a1a,stroke:#ef4444,color:#e2e8f0
    classDef store fill:#1a2d3d,stroke:#06b6d4,color:#e2e8f0
    classDef api fill:#2d2d1a,stroke:#eab308,color:#e2e8f0
    classDef front fill:#1a3d2d,stroke:#22c55e,color:#e2e8f0
    classDef infra fill:#2d2d2d,stroke:#64748b,color:#e2e8f0

    class FG,WIN,M365,AZ,SYS source
    class SYSLOG,POLLER,RING ingest
    class P_INT,P_FG,P_WIN,P_M365,P_AZ,P_SYS parse
    class EVT schema
    class RLOAD,RENG,RYAML rule
    class SENG,SQLITE,RET store
    class SRV,EP_H,EP_E,EP_S api
    class DASH front
    class MAIN,LOG,UTIL infra
