	$(MAKE) $(MAKESILENT) -f CMakeFiles/outpost_tests.dir/build.make CMakeFiles/outpost_tests.dir/tests/test_storage.cpp.i
.PHONY : tests/test_storage.cpp.i

tests/test_storage.s: tests/test_storage.cpp.s
.PHONY : tests/test_storage.s

# target to generate assembly for a file
tests/test_storage.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/outpost_tests.dir/build.make CMakeFiles/outpost_tests.dir/tests/test_storage.cpp.s
.PHONY : tests/test_storage.cpp.s

